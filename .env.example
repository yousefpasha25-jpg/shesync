# SheSync Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Gemini AI (required for AI features)
# Use GEMINI_API_KEY (preferred) or GOOGLE_API_KEY — both are checked
GEMINI_API_KEY=your_google_gemini_api_key

# Upstash Redis — required for production rate limiting
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Dev-only: set to "true" to bypass Gemini and use hardcoded mock plans
# Only active when NODE_ENV=development
NEXT_PUBLIC_USE_MOCK_AI=false
